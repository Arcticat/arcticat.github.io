---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} · Chenghan Song`} description={post.data.description}>
  <article class="post">
    <header class="post-header">
      <span class="chips">
        <span class="chip">
          <time datetime={post.data.date.toISOString()}>
            {
              post.data.date.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })
            }
          </time>
        </span>
        {
          post.data.tags.map((tag) => (
            <a class="chip chip--tag" href={`/tags/${tag}/`}>
              {tag}
            </a>
          ))
        }
      </span>
      <h1>{post.data.title}</h1>
    </header>
    <div class="post-body">
      <Content />
    </div>
    <footer class="post-footer">
      <a class="pill" href="/blog">← All posts</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post {
    background: var(--card);
    border-radius: 18px;
    padding: 3rem 2.6rem 2.6rem;
    box-shadow: 0 3px 0 var(--card-edge);
  }

  .post-header,
  .post-body,
  .post-footer {
    max-width: 44rem;
    margin-inline: auto;
  }

  .post-header h1 {
    font-size: clamp(1.8rem, 4.5vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0.7rem 0 0;
  }

  .post-body {
    margin-top: 1.6rem;
  }

  .post-body :global(img) {
    max-width: 100%;
    border-radius: 12px;
  }

  .post-body :global(pre) {
    padding: 1rem 1.2rem;
    border-radius: 12px;
    overflow-x: auto;
    font-size: 0.9rem;
  }

  .post-body :global(blockquote) {
    margin: 1.5rem 0;
    padding-left: 1rem;
    border-left: 4px solid var(--sun);
    color: var(--ink-soft);
  }

  .post-footer {
    margin-top: 2.2rem;
  }

  @media (max-width: 40rem) {
    .post {
      padding: 1.6rem 1.3rem;
    }
  }
</style>
