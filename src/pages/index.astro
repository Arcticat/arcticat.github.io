---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Chenghan Song">
  <section class="hero">
    <h1>Hi, I'm <span class="mark">Chenghan Song</span> — I chase interesting data.</h1>
    <p class="bio">
      A data enthusiast who loves exploring new things. I write here about
      data, ideas, and whatever I'm currently curious about.
    </p>
  </section>

  <section class="recent">
    <h2 class="section-title">Recent writing</h2>
    <div class="post-grid">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
    <a class="pill all-posts" href="/blog">All posts →</a>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--panel);
    border-radius: 20px;
    padding: 2.6rem 2.4rem 2.4rem;
    margin-bottom: 2.6rem;
  }

  .hero::after {
    content: '';
    position: absolute;
    right: -3.5rem;
    top: -3.5rem;
    width: 11rem;
    height: 11rem;
    border-radius: 50%;
    background: var(--sun);
    opacity: 0.9;
  }

  .hero::before {
    content: '';
    position: absolute;
    right: 3.5rem;
    bottom: -4.5rem;
    width: 9rem;
    height: 9rem;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.22;
  }

  .hero > * {
    position: relative;
    z-index: 1;
  }

  .hero h1 {
    font-size: clamp(1.9rem, 5vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    max-width: 24ch;
  }

  .mark {
    color: var(--accent);
  }

  .bio {
    font-size: 1.1rem;
    color: var(--ink-soft);
    max-width: 32rem;
    margin: 0;
  }

  .post-grid {
    margin: 1.3rem 0 0.5rem;
  }

  @media (max-width: 40rem) {
    .hero {
      padding: 2rem 1.5rem;
    }
  }
</style>
